#!/usr/bin/env python3
"""
EduBot Lane Follower  –  v3
============================

Road convention
---------------
  WHITE solid line   → RIGHT boundary  (must stay to the robot's RIGHT)
  YELLOW dashed line → LEFT  boundary  (must stay to the robot's LEFT)

The robot drives INSIDE the lane, not on top of the lines.

Key design decisions
--------------------

1. ROBOT-BODY OFFSET
   The camera sits at the robot's centre but the robot body is wider.
   camera_offset_px shifts the effective target point LEFT so the robot
   keeps its right body edge clear of the white line.
   Default: 30 px (tune with camera_offset_px param).

2. LANE-CENTRE TARGET (not line target)
   When both lines are visible the robot drives toward the geometric
   centre of the lane MINUS the body offset.
   When only the white line is visible the robot targets a fixed fraction
   LEFT of that line (white_only_gap_frac), minus offset.
   When only yellow is visible it targets a fixed fraction RIGHT of it.

3. WHITE-LINE REJECTION (anti-reflection)
   - white_s_min default 0 (raise to 25-50 indoors to kill glare).
   - Morphological open (noise removal) before contour search.
   - Minimum contour AREA and minimum contour WIDTH filters stop small
     specular hotspots being mistaken for the lane line.
   - Frame-to-frame JUMP REJECTION: if white centroid moves more than
     max_cx_jump_px pixels in one frame, that reading is discarded.

4. YELLOW DASHED LINE DETECTION
   - yellow_h range widened (12-40) and yellow_v_min lowered to 50.
   - ALL qualifying contours are kept and a WEIGHTED centroid is computed
     (heavier weight for larger blobs). This keeps the centroid stable
     across gaps in the dashes.

5. TURN DETECTION (left / right)
   Tracks where detected lines are vs where they are normally expected.
   If the white line (normally far right) suddenly appears near centre
   the robot is entering a RIGHT turn.
   If the yellow line (normally far left) suddenly moves right the robot
   is entering a LEFT turn.
   In both cases linear_speed is reduced and angular gain is increased.

6. DYNAMIC HSV
   Every threshold is a live ROS 2 parameter. Nothing requires a restart.
   Current values are overlaid on the debug image.

Tune live
---------
  ros2 param set /lane_follower white_s_min 40
  ros2 param set /lane_follower yellow_v_min 50
  ros2 param set /lane_follower camera_offset_px 40
  ros2 param set /lane_follower kp 0.004
"""

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
from geometry_msgs.msg import Twist
from cv_bridge import CvBridge
from rcl_interfaces.msg import ParameterDescriptor, SetParametersResult
import cv2
import numpy as np

CAMERA_TOPIC  = '/camera_1/image_raw'
CMD_VEL_TOPIC = '/cmd_vel'
DEBUG_TOPIC   = '/lane_debug/image_raw'


class LaneFollower(Node):

    def __init__(self):
        super().__init__('lane_follower')
        self.bridge = CvBridge()

        # Track previous centroids for jump-rejection
        self._prev_white_cx  = None
        self._prev_yellow_cx = None

        # ── Declare parameters ────────────────────────────────────────────────
        def p(desc):
            return ParameterDescriptor(description=desc)

        # White HSV
        self.declare_parameter('white_h_min',  0,   p('White hue min (0-180)'))
        self.declare_parameter('white_h_max',  180, p('White hue max'))
        self.declare_parameter('white_s_min',  0,   p('White sat min – RAISE to kill reflections (try 25-60)'))
        self.declare_parameter('white_s_max',  60,  p('White sat max'))
        self.declare_parameter('white_v_min',  190, p('White val min'))
        self.declare_parameter('white_v_max',  255, p('White val max'))

        # Yellow HSV
        self.declare_parameter('yellow_h_min', 12,  p('Yellow hue min'))
        self.declare_parameter('yellow_h_max', 40,  p('Yellow hue max'))
        self.declare_parameter('yellow_s_min', 60,  p('Yellow sat min'))
        self.declare_parameter('yellow_s_max', 255, p('Yellow sat max'))
        self.declare_parameter('yellow_v_min', 50,  p('Yellow val min – lower for dim dashes'))
        self.declare_parameter('yellow_v_max', 255, p('Yellow val max'))

        # ROI
        self.declare_parameter('roi_top_frac', 0.38,
            p('Top of ROI as fraction of frame height. 0.38 = look at lower 62%'))

        # Robot body offset
        self.declare_parameter('camera_offset_px', 30,
            p('Pixels to shift target LEFT to account for robot body width'))

        # Lane geometry targets
        self.declare_parameter('white_only_gap_frac', 0.18,
            p('When only white visible: target this fraction LEFT of white cx'))
        self.declare_parameter('yellow_only_gap_frac', 0.18,
            p('When only yellow visible: target this fraction RIGHT of yellow cx'))

        # Driving
        self.declare_parameter('linear_speed',  0.12,  p('Normal forward speed m/s'))
        self.declare_parameter('turn_speed',     0.07,  p('Forward speed during turns m/s'))
        self.declare_parameter('kp',             0.004, p('Steering proportional gain'))
        self.declare_parameter('turn_kp_scale',  1.6,   p('Multiply kp by this during turns'))
        self.declare_parameter('max_angular',    0.65,  p('Max angular velocity rad/s'))
        self.declare_parameter('min_area',       400,   p('Min contour area (px2) to count as line'))
        self.declare_parameter('min_width',      8,     p('Min contour bounding-box width (px)'))

        # Reflection / jump rejection
        self.declare_parameter('max_cx_jump_px', 120,
            p('Max white-cx jump between frames before discarding as reflection'))

        # Turn detection
        self.declare_parameter('turn_white_frac',  0.50,
            p('White cx below this fraction of width triggers right-turn mode'))
        self.declare_parameter('turn_yellow_frac', 0.55,
            p('Yellow cx above this fraction of width triggers left-turn mode'))

        self.add_on_set_parameters_callback(self.param_callback)
        self.load_params()

        self.sub = self.create_subscription(
            Image, CAMERA_TOPIC, self.image_cb, 1)
        self.pub = self.create_publisher(Twist, CMD_VEL_TOPIC, 10)
        self.debug_pub = self.create_publisher(Image, DEBUG_TOPIC, 1)

        self.get_logger().info(
            f'EduBot lane follower v3 ready\n'
            f'  Camera : {CAMERA_TOPIC}\n'
            f'  Debug  : {DEBUG_TOPIC}\n'
            f'  Tune   : ros2 param set /lane_follower <param> <value>'
        )

    # ── Parameter management ───────────────────────────────────────────────────

    def load_params(self):
        gp = self.get_parameter

        self.white_lower  = np.array([gp('white_h_min').value,
                                       gp('white_s_min').value,
                                       gp('white_v_min').value], dtype=np.uint8)
        self.white_upper  = np.array([gp('white_h_max').value,
                                       gp('white_s_max').value,
                                       gp('white_v_max').value], dtype=np.uint8)
        self.yellow_lower = np.array([gp('yellow_h_min').value,
                                       gp('yellow_s_min').value,
                                       gp('yellow_v_min').value], dtype=np.uint8)
        self.yellow_upper = np.array([gp('yellow_h_max').value,
                                       gp('yellow_s_max').value,
                                       gp('yellow_v_max').value], dtype=np.uint8)

        self.roi_top_frac         = float(gp('roi_top_frac').value)
        self.camera_offset_px     = int(gp('camera_offset_px').value)
        self.white_only_gap_frac  = float(gp('white_only_gap_frac').value)
        self.yellow_only_gap_frac = float(gp('yellow_only_gap_frac').value)
        self.linear_speed         = float(gp('linear_speed').value)
        self.turn_speed           = float(gp('turn_speed').value)
        self.kp                   = float(gp('kp').value)
        self.turn_kp_scale        = float(gp('turn_kp_scale').value)
        self.max_angular          = float(gp('max_angular').value)
        self.min_area             = int(gp('min_area').value)
        self.min_width            = int(gp('min_width').value)
        self.max_cx_jump_px       = int(gp('max_cx_jump_px').value)
        self.turn_white_frac      = float(gp('turn_white_frac').value)
        self.turn_yellow_frac     = float(gp('turn_yellow_frac').value)

    def param_callback(self, params):
        self.load_params()
        return SetParametersResult(successful=True)

    # ── Vision helpers ─────────────────────────────────────────────────────────

    def _clean_mask(self, mask):
        """Open (kill specks) then close (bridge dash gaps)."""
        k3 = cv2.getStructuringElement(cv2.MORPH_RECT, (3, 3))
        k7 = cv2.getStructuringElement(cv2.MORPH_RECT, (7, 7))
        mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN,  k3, iterations=2)
        mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, k7, iterations=3)
        return mask

    def get_cx_white(self, mask):
        """
        White (solid) line centroid.
        Takes the SINGLE largest qualifying contour.
        Applies area + width filter to reject specular blobs.
        Returns (cx, [valid contours]) or (None, []).
        """
        mask = self._clean_mask(mask)
        contours, _ = cv2.findContours(
            mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        valid = []
        for c in contours:
            if cv2.contourArea(c) < self.min_area:
                continue
            _x, _y, cw, _h = cv2.boundingRect(c)
            if cw < self.min_width:
                continue
            valid.append(c)
        if not valid:
            return None, []
        biggest = max(valid, key=cv2.contourArea)
        M = cv2.moments(biggest)
        if M['m00'] == 0:
            return None, valid
        return int(M['m10'] / M['m00']), valid

    def get_cx_yellow(self, mask):
        """
        Yellow (dashed) line centroid.
        Uses ALL qualifying contours and computes an AREA-WEIGHTED centroid
        so the position stays stable across the gaps between dashes.
        Returns (cx, [valid contours]) or (None, []).
        """
        mask = self._clean_mask(mask)
        contours, _ = cv2.findContours(
            mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        valid = []
        for c in contours:
            if cv2.contourArea(c) < self.min_area:
                continue
            _x, _y, cw, _h = cv2.boundingRect(c)
            if cw < self.min_width:
                continue
            valid.append(c)
        if not valid:
            return None, []

        total_area  = 0.0
        weighted_cx = 0.0
        for c in valid:
            M = cv2.moments(c)
            if M['m00'] == 0:
                continue
            cx   = M['m10'] / M['m00']
            area = M['m00']
            weighted_cx += cx * area
            total_area  += area
        if total_area == 0:
            return None, valid
        return int(weighted_cx / total_area), valid

    # ── Main callback ──────────────────────────────────────────────────────────

    def image_cb(self, msg: Image):
        frame = self.bridge.imgmsg_to_cv2(msg, desired_encoding='bgr8')
        h, w  = frame.shape[:2]

        # ── ROI ───────────────────────────────────────────────────────────────
        roi_y = int(h * self.roi_top_frac)
        roi   = frame[roi_y:, :]
        rh, rw = roi.shape[:2]

        # ── HSV thresholding ──────────────────────────────────────────────────
        blurred = cv2.GaussianBlur(roi, (5, 5), 0)
        hsv     = cv2.cvtColor(blurred, cv2.COLOR_BGR2HSV)

        white_mask  = cv2.inRange(hsv, self.white_lower,  self.white_upper)
        yellow_mask = cv2.inRange(hsv, self.yellow_lower, self.yellow_upper)

        raw_white_cx,  white_contours  = self.get_cx_white(white_mask)
        raw_yellow_cx, yellow_contours = self.get_cx_yellow(yellow_mask)

        # ── Reflection / jump rejection for white ─────────────────────────────
        white_cx = raw_white_cx
        if (raw_white_cx is not None
                and self._prev_white_cx is not None
                and abs(raw_white_cx - self._prev_white_cx) > self.max_cx_jump_px):
            white_cx = self._prev_white_cx
            self.get_logger().warn(
                f'White cx jump {self._prev_white_cx}->{raw_white_cx} discarded (reflection?)',
                throttle_duration_sec=0.5)

        yellow_cx = raw_yellow_cx

        if raw_white_cx  is not None:
            self._prev_white_cx  = raw_white_cx
        if raw_yellow_cx is not None:
            self._prev_yellow_cx = raw_yellow_cx

        # ── Turn detection ────────────────────────────────────────────────────
        #
        # RIGHT TURN: white line (normally far right, ~0.70 rw) moves LEFT
        #             Trigger when white_cx < turn_white_frac * rw
        #
        # LEFT TURN:  yellow line (normally far left, ~0.25 rw) moves RIGHT
        #             Trigger when yellow_cx > turn_yellow_frac * rw
        #
        in_right_turn = (white_cx  is not None and
                         white_cx  < int(rw * self.turn_white_frac))
        in_left_turn  = (yellow_cx is not None and
                         yellow_cx > int(rw * self.turn_yellow_frac))
        in_turn       = in_right_turn or in_left_turn

        # ── Debug image ────────────────────────────────────────────────────────
        debug = frame.copy()
        cv2.line(debug, (0, roi_y), (w, roi_y), (200, 200, 200), 2)

        if white_contours:
            shifted = [c + np.array([[[0, roi_y]]]) for c in white_contours]
            cv2.drawContours(debug, shifted, -1, (255, 80, 0), 3)      # blue/orange

        if yellow_contours:
            shifted = [c + np.array([[[0, roi_y]]]) for c in yellow_contours]
            cv2.drawContours(debug, shifted, -1, (0, 215, 255), 3)     # yellow

        mid_y = roi_y + rh // 2

        if white_cx is not None:
            cv2.circle(debug, (white_cx, mid_y), 14, (255, 80, 0), -1)
            cv2.putText(debug, f'W={white_cx}',
                        (max(0, white_cx - 50), mid_y - 20),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.75, (255, 200, 100), 2)

        if yellow_cx is not None:
            cv2.circle(debug, (yellow_cx, mid_y), 14, (0, 215, 255), -1)
            cv2.putText(debug, f'Y={yellow_cx}',
                        (max(0, yellow_cx - 50), mid_y + 35),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.75, (180, 255, 255), 2)

        cv2.line(debug, (w // 2, roi_y), (w // 2, h), (180, 180, 180), 1)

        # ── Steering logic ────────────────────────────────────────────────────
        #
        # target_x is in ROI x-coordinates.
        # Subtracting camera_offset_px shifts aim LEFT = keeps body off white line.
        # error = target_x - rw/2  (positive = target is right of centre = steer left)
        #
        twist    = Twist()
        error    = None
        target_x = None
        status   = 'NO LINES'

        if white_cx is not None and yellow_cx is not None:
            if white_cx > yellow_cx:
                # Normal geometry: drive at lane centre minus body offset
                lane_center = (white_cx + yellow_cx) / 2.0
                target_x    = lane_center - self.camera_offset_px
                turn_tag    = 'R-TURN' if in_right_turn else ('L-TURN' if in_left_turn else '')
                status      = f'BOTH {turn_tag}'
            else:
                # Lines crossed (tight corner recovery) – trust yellow
                target_x = (yellow_cx + int(rw * self.yellow_only_gap_frac)
                             - self.camera_offset_px)
                status = 'CROSSED->Y'

        elif white_cx is not None:
            # White only: stay a gap-fraction to its left
            gap      = int(rw * self.white_only_gap_frac)
            target_x = white_cx - gap - self.camera_offset_px
            status   = 'WHITE-ONLY' + ('  R-TURN' if in_right_turn else '')

        elif yellow_cx is not None:
            # Yellow only: stay a gap-fraction to its right
            gap      = int(rw * self.yellow_only_gap_frac)
            target_x = yellow_cx + gap - self.camera_offset_px
            status   = 'YELLOW-ONLY' + ('  L-TURN' if in_left_turn else '')

        if target_x is not None:
            error = target_x - (rw / 2.0)

        # Draw target marker
        if target_x is not None:
            tx = int(np.clip(target_x, 0, w - 1))
            cv2.circle(debug, (tx, mid_y), 10, (0, 255, 255), -1)
            cv2.line(debug, (tx, roi_y), (tx, h), (0, 255, 255), 2)

        # Status overlay
        err_str     = f'  err={error:+.0f}' if error is not None else ''
        full_status = status + err_str
        s_color = (0, 255, 0) if (error is not None and abs(error) < 60) else (0, 100, 255)
        cv2.putText(debug, full_status, (15, 40),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.9, s_color, 2)

        # HSV readout
        cv2.putText(debug,
            f'W s:{self.white_lower[1]}-{self.white_upper[1]}'
            f' v:{self.white_lower[2]}+  '
            f'Y h:{self.yellow_lower[0]}-{self.yellow_upper[0]}'
            f' v:{self.yellow_lower[2]}+',
            (10, h - 12), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (210, 210, 210), 1)

        self.debug_pub.publish(
            self.bridge.cv2_to_imgmsg(debug, encoding='bgr8'))

        # ── Publish cmd_vel ────────────────────────────────────────────────────
        if error is None:
            self.get_logger().warn(
                'No lines — sweeping left to search', throttle_duration_sec=2.0)
            twist.angular.z = 0.18
            self.pub.publish(twist)
            return

        self.get_logger().info(full_status, throttle_duration_sec=0.5)

        effective_kp = self.kp * (self.turn_kp_scale if in_turn else 1.0)
        fwd_speed    = self.turn_speed if in_turn else self.linear_speed

        # Positive error = target right of centre = steer LEFT = negative z
        angular = float(np.clip(
            -effective_kp * error,
            -self.max_angular, self.max_angular))

        twist.linear.x  = fwd_speed
        twist.angular.z = angular
        self.pub.publish(twist)


# ── Entry point ────────────────────────────────────────────────────────────────

def main(args=None):
    rclpy.init(args=args)
    node = LaneFollower()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.pub.publish(Twist())
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
